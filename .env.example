# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Etherscan/Basescan API key for contract verification
ETHERSCAN_API_KEY=
BLOCKSCOUT_VERIFIER_URL=https://base.blockscout.com/api/

# Deployer address (from keystore). One-shot keypair; retired after deploy. Never plays.
DEPLOYER_ADDRESS=

# Owner / operator address. Receives ownership of Rewards + GuessGame at construction.
# MUST differ from DEPLOYER_ADDRESS — enforces the Phase B three-role separation
# (deployer / funding / operator are three distinct keypairs, none of which ever plays).
OWNER=