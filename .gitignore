# Compiler files
cache/
out/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/
# run-latest.json is overwritten on every broadcast — keep timestamped runs only
/broadcast/**/run-latest.json

# Docs (forge doc output) — allow hand-written specs under docs/superpowers/ and security disclosures under docs/security/
docs/*
!docs/superpowers/
!docs/security/

# Dotenv file
.env
.env.local

# Secrets
.secrets

# Settlement scripts and cache (contain addresses/amounts)
settle-mainnet.sh
discover-unsettled.sh
.settle-cache/

# One-time migration artifacts and scratch scripts (not part of main project)
archive/
node_modules/

# Remix compiler artifacts
**/artifacts/
**/artifacts/**

# Remix plugin state folders
deps/
states/

# Debug info
*.dbg.json
*.tsbuildinfo

# Deprecated scripts
script/deprecated/

# Rewards epoch artifacts (live in chainhackers/zk-guess-rewards, never here)
epochs/

# Bun lockfile — npm/package-lock.json is canonical (CI runs `npm ci`)
bun.lock

# Circuit artifacts - versioned directories are committed
# circuits/
